{
  "name": "utxwallet",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "react-native run-android && react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "format": "prettier --write .",
    "test:ci": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:ci",
    "build": "npm run build:android",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "clean:android": "cd android && ./gradlew clean",
    "android:active": "react-native run-android --active-arch-only",
    "build:android:debug:x86_64": "cd android && ./gradlew assembleDebug -PreactNativeArchitectures=x86_64"
  },
  "dependencies": {
    "@mempool/mempool.js": "^3.0.0",
    "@op-engineering/op-sqlite": "^16.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native/new-app-screen": "0.85.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "bitcoin-tx-lib": "^0.5.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-get-random-values": "^2.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "react-native": {
    "assets": [
      "./assets/images"
    ]
  }
}
