# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit the real file.
#
# Generate the keystore with:
#   keytool -genkey -v -keystore android/app/utxwallet-release.keystore \
#     -alias utxwallet-key -keyalg RSA -keysize 2048 -validity 10000

UTXWALLET_UPLOAD_STORE_FILE=utxwallet-release.keystore
UTXWALLET_UPLOAD_KEY_ALIAS=utxwallet-key
UTXWALLET_UPLOAD_STORE_PASSWORD=your_store_password
UTXWALLET_UPLOAD_KEY_PASSWORD=your_key_password
